# ─────────────────────────────────────────────────────────────
# fixvesta.com — local environment
# Copy this file to `.env.local` and fill in real values.
# .env.local is git-ignored and never reaches Vercel/GitHub
# unless you add it via the Vercel dashboard (recommended).
# ─────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────
# Local Docker: docker run -d --name staking-db -e POSTGRES_PASSWORD=stakingpass -e POSTGRES_DB=staking_db -p 5432:5432 postgres:15
# Production:   Supabase / Railway / Neon connection string
DATABASE_URL=postgresql://postgres:stakingpass@localhost:5432/staking_db

# ── JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-random-96-char-hex

# ── Admin wallets (comma-separated, lowercase) ─────────────
ADMIN_WALLETS=0xYOUR_ADMIN_WALLET

# ── BSC (USDT BEP20) ───────────────────────────────────────
NEXT_PUBLIC_BSC_STAKING_CONTRACT=
NEXT_PUBLIC_BSC_USDT=0x55d398326f99059fF775485246999027B3197955
NEXT_PUBLIC_BSC_RPC=https://bsc-dataseed.binance.org/
NEXT_PUBLIC_BSC_CHAIN_ID=56

# ── TRON (USDT TRC20) ──────────────────────────────────────
NEXT_PUBLIC_TRON_STAKING_CONTRACT=
NEXT_PUBLIC_TRON_USDT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
NEXT_PUBLIC_TRON_RPC=https://api.trongrid.io

# ── Solana (USDC SPL) ──────────────────────────────────────
NEXT_PUBLIC_SOL_PROGRAM_ID=
NEXT_PUBLIC_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_SOL_RPC=https://api.mainnet-beta.solana.com

# ── App identity ───────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=fixvesta
NEXT_PUBLIC_APP_URL=https://fixvesta.com

# ─────────────────────────────────────────────────────────────
# Legacy / hidden — CBT/CBB presale (kept for .internal bot, do not expose)
# Public site no longer renders these; they exist only if you keep the
# presale-bot running locally.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CBB_MINT=
NEXT_PUBLIC_TREASURY_WALLET=
NEXT_PUBLIC_PRESALE_WALLET=
NEXT_PUBLIC_STAKING_WALLET=
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PRESALE_PRIVATE_KEY=
TOKEN_METADATA_URI=
